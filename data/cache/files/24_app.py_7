            Question: {input}
            Thought: {agent_scratchpad}
        """
        )
    agente = create_react_agent(llm=llm, tools=tools, prompt=prompt_react_es)
    orquestador = AgentExecutor(agent=agente,
                                tools=tools,
                                verbose=True,
                                handle_parsing_errors=True)
    st.markdown("---")
    st.markdown("## ⚡ Acciones rápidas")